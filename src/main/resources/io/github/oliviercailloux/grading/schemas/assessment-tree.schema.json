{
  "$id": "https://raw.githubusercontent.com/oliviercailloux/grading-schema/main/assessment-tree.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/assessmentTree",
  "$defs": {
    "assessmentTree": {
      "oneOf": [
        {
          "$ref": "#/$defs/assessment"
        },
        {
          "$ref": "#/$defs/composite"
        }
      ]
    },
    "assessment": {
      "type": "object",
      "required": [
        "mark"
      ],
      "properties": {
        "mark": {
          "type": "number"
        },
        "feedback": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "unevaluatedProperties": false
    },
    "composite": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/assessmentTree"
      },
      "minProperties": 1,
      "unevaluatedProperties": false
    }
  }
}
