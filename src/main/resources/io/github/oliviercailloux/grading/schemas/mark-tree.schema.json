{
  "$id": "https://raw.githubusercontent.com/oliviercailloux/grading-schema/main/mark-tree.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "$ref": "#/$defs/leafMark"
    },
    {
      "$ref": "#/$defs/compositeMark"
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "labeled": {
      "type": "object",
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string"
        }
      }
    },
    "leafMark": {
      "type": "object",
      "required": [
        "mark"
      ],
      "properties": {
        "mark": {
          "type": "number"
        }
      }
    },
    "compositeMark": {
      "type": "object",
      "required": [
        "children"
      ],
      "properties": {
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labeledMark"
          }
        }
      }
    },
    "labeledLeafMark": {
      "allOf": [
        {
          "$ref": "#/$defs/labeled"
        },
        {
          "$ref": "#/$defs/leafMark"
        }
      ],
      "unevaluatedProperties": false
    },
    "labeledCompositeMark": {
      "allOf": [
        {
          "$ref": "#/$defs/labeled"
        },
        {
          "$ref": "#/$defs/compositeMark"
        }
      ],
      "unevaluatedProperties": false
    },
    "labeledMark": {
      "type": "object",
      "oneOf": [
        {
          "$ref": "#/$defs/labeledLeafMark"
        },
        {
          "$ref": "#/$defs/labeledCompositeMark"
        }
      ]
    }
  }
}
