{
  "$id": "https://raw.githubusercontent.com/oliviercailloux/grading-schema/main/mark-tree.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/markTree",
  "$defs": {
    "markTree": {
      "oneOf": [
        {
          "$ref": "#/$defs/mark"
        },
        {
          "$ref": "#/$defs/composite"
        }
      ]
    },
    "mark": {
      "type": "object",
      "required": [
        "mark"
      ],
      "properties": {
        "mark": {
          "type": "number"
        }
      },
      "additionalProperties": false,
      "unevaluatedProperties": false
    },
    "composite": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/markTree"
      },
      "minProperties": 1,
      "unevaluatedProperties": false
    }
  }
}
